# Vercel Postgres (자동 주입되지만 로컬 개발용으로 .env.local에 복사 필요)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Vercel Blob (자동 주입)
BLOB_READ_WRITE_TOKEN=

# OpenAI (TTS용)
OPENAI_API_KEY=

# Anthropic (Claude API - 철자검사, 학습정보 생성)
ANTHROPIC_API_KEY=

# 사이트 URL (URL 복사 버튼용, 선택)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
